# Generated ATLAS simulation deck for dryrun_pn_complete.
# This deck reads the structure generated by the first-step builder.

go atlas

mesh infile="dryrun_pn_complete_device.str"


models srh conmob fldmob fermi
method newton
solve init

log outf="dryrun_pn_complete_iv.log"
solve name=anode vanode=-1.0 vstep=0.1 vfinal=1.0
log off

save outf="dryrun_pn_complete_final.str"
quit