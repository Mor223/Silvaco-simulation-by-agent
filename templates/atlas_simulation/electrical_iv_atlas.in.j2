# Generated ATLAS simulation deck for {{ case_name }}.
# This deck reads the structure generated by the first-step builder.

go atlas

mesh infile="{{ structure_input }}"

{% if contacts is defined -%}
{% for contact in contacts -%}
contact name={{ contact.name }}{% if contact.workfunction is defined %} workfunction={{ contact.workfunction }}{% endif %}
{% endfor %}
{% endif -%}
models {{ models | join(' ') }}
method {{ method }}
solve init

log outf="{{ iv_log }}"
{% for sweep in sweeps -%}
solve name={{ sweep.electrode }} v{{ sweep.electrode }}={{ sweep.start }} vstep={{ sweep.step }} vfinal={{ sweep.stop }}
{% endfor -%}
log off

save outf="{{ final_structure }}"
quit
